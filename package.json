{
  "name": "ciclista",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
